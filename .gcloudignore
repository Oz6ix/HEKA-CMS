# This file controls what gcloud uploads to Cloud Build
# Vendor libraries are now loaded from CDN — only upload custom theme files

.git
.env
.env.backup
node_modules
vendor
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
tests
docker-compose.yml
.phpunit*
.vscode
.idea
.fleet
.nova
.zed
database/*.sqlite
database/*.sqlite-journal

# Exclude the 200MB vendor asset directories (loaded from CDN now)
public/assets/backend/vendors/
public/assets/frontend/vendors/
public/assets/frontend/bootbox/
public/assets/frontend/css/
public/assets/frontend/js/
public/assets/frontend/media/

# Keep: public/assets/backend/css/ (KT theme, ~2MB)
# Keep: public/assets/backend/js/ (KT scripts, ~1MB)
# Keep: public/assets/backend/bootbox/ (~50KB)
# Keep: public/assets/brand/ (~100KB)
