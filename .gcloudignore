# This file controls what gets uploaded to Google Cloud Build
# It is SEPARATE from .gitignore — assets don't need to be in git
# but DO need to be uploaded to Cloud Build

.git
.gitignore
.env
.env.backup
node_modules
vendor
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
tests
docker-compose.yml
.phpunit*
.vscode
.idea
.fleet
.nova
.zed
database/*.sqlite
database/*.sqlite-journal

# NOTE: public/assets/ is NOT excluded here — it gets uploaded to Cloud Build
